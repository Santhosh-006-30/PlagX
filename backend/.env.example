# App Settings
APP_NAME="PlagX Plagiarism API"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Database
# Format: postgresql+asyncpg://user:password@localhost:5432/plagx
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/plagx
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Security
# Generate using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
